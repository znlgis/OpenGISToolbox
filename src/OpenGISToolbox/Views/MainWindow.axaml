<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGISToolbox.ViewModels"
        xmlns:m="using:OpenGISToolbox.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="600"
        x:Class="OpenGISToolbox.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{DynamicResource WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="200,Auto,250,Auto,*">
        <!-- Categories Panel -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,12,12,8">
                    <TextBlock Grid.Column="0" Text="{DynamicResource ToolCategories}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="{DynamicResource LanguageLabel}" Command="{Binding SwitchLanguageCommand}"
                            FontSize="11" Padding="6,2" VerticalAlignment="Center" />
                </Grid>
                <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategoryItem}" Margin="4,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:ToolCategoryItem">
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ToolCountDisplay}" FontSize="11" Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" Background="Transparent" />

        <!-- Tools List Panel -->
        <Border Grid.Column="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Tools}" FontWeight="Bold" FontSize="14" Margin="12,12,12,8" />
                <ListBox ItemsSource="{Binding FilteredTools}" SelectedItem="{Binding SelectedTool}" Margin="4,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:ToolInfo">
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DisplayDescription}" FontSize="11" Foreground="Gray"
                                           TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns" Background="Transparent" />

        <!-- Execution Panel -->
        <ContentControl Grid.Column="4" Content="{Binding ExecutionViewModel}" />
    </Grid>
</Window>
